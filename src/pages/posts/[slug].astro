---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getPostFacets } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { categories, tags } = await getPostFacets();
---

<SiteLayout
  title={`${post.data.title} | myblog`}
  currentPath="/posts"
  categories={categories}
  tags={tags}
>
  <article class="article-card">
    <header
      class="hero"
      style={`--cover-from:${post.data.coverFrom}; --cover-to:${post.data.coverTo};`}
    >
      <p class="meta">{post.data.category} / {post.data.publishDate.toLocaleDateString("zh-CN")}</p>
      <h1>{post.data.title}</h1>
      <p class="excerpt">{post.data.excerpt}</p>
      <div class="tag-row">
        {post.data.tags.map((tag) => (
          <span>#{tag}</span>
        ))}
      </div>
    </header>

    <div class="content">
      <Content />
    </div>
  </article>
</SiteLayout>

<style>
  .article-card {
    overflow: hidden;
    border-radius: 1.9rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
  }

  .hero {
    padding: 2rem;
    color: white;
    background: linear-gradient(135deg, var(--cover-from), var(--cover-to));
  }

  .meta {
    margin: 0;
    opacity: 0.84;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.8rem;
  }

  h1 {
    margin: 0.6rem 0;
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 0.98;
  }

  .excerpt {
    max-width: 48rem;
    margin: 0;
    font-size: 1.08rem;
    color: rgba(255, 255, 255, 0.88);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.1rem;
  }

  .tag-row span {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
  }

  .content {
    padding: 2rem;
  }

  .content :global(p) {
    color: #334155;
    font-size: 1.06rem;
  }
</style>
