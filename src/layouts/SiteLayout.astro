---
import Sidebar from "../components/Sidebar.astro";
import RightRail from "../components/RightRail.astro";

const {
  title = "myblog",
  currentPath = "/",
  categories = [],
  tags = [],
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <div class="left-column">
        <Sidebar currentPath={currentPath} />
      </div>
      <main class="main-column">
        <slot />
      </main>
      <div class="right-column">
        <RightRail categories={categories} tags={tags} />
      </div>
    </div>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    font-family: "IBM Plex Sans", "Noto Sans SC", system-ui, sans-serif;
    line-height: 1.5;
    background: #f5efe7;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: #0f172a;
    background:
      radial-gradient(circle at top left, rgba(249, 115, 22, 0.18), transparent 26%),
      radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.2), transparent 28%),
      linear-gradient(180deg, #f8f3ec, #f4efe8 38%, #f1ece4);
  }

  .page-shell {
    width: min(1500px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 1.2rem 0 2rem;
    display: grid;
    grid-template-columns: minmax(180px, 0.9fr) minmax(0, 5.6fr) minmax(240px, 1.4fr);
    gap: 1.25rem;
    align-items: start;
  }

  .left-column,
  .right-column {
    position: sticky;
    top: 1rem;
  }

  .main-column {
    position: static;
  }

  @media (max-width: 1100px) {
    .page-shell {
      grid-template-columns: 220px minmax(0, 1fr);
    }

    .right-column {
      grid-column: 1 / -1;
      position: static;
    }
  }

  @media (max-width: 860px) {
    .page-shell {
      width: min(100vw - 1rem, 900px);
      grid-template-columns: 1fr;
    }

    .left-column,
    .right-column {
      position: static;
    }
  }
</style>
