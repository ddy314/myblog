---
const { post } = Astro.props;
const { data, id } = post;
const base = import.meta.env.BASE_URL;
const slug = id.replace(/\.(md|mdx)$/, "");
---

<article
  class="post-card"
  data-post-card
  data-title={data.title.toLowerCase()}
  data-excerpt={data.excerpt.toLowerCase()}
  data-category={data.category}
  data-tags={data.tags.join("|").toLowerCase()}
>
  <a href={`${base}posts/${slug}/`} class="post-link">
    <div
      class="cover"
      style={`--cover-from:${data.coverFrom}; --cover-to:${data.coverTo};`}
      aria-hidden="true"
    >
      <span>{data.category}</span>
    </div>
    <div class="content">
      <p class="meta">{data.publishDate.toLocaleDateString("zh-CN")}</p>
      <h2>{data.title}</h2>
      <p class="excerpt">{data.excerpt}</p>
      <div class="tags">
        {data.tags.map((tag) => (
          <span>#{tag}</span>
        ))}
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    border-radius: 1.7rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(148, 163, 184, 0.18);
    box-shadow: 0 22px 44px rgba(15, 23, 42, 0.08);
  }

  .post-link {
    display: grid;
    grid-template-columns: minmax(11rem, 18rem) 1fr;
    color: inherit;
    text-decoration: none;
  }

  .cover {
    min-height: 100%;
    display: grid;
    place-items: end start;
    padding: 1.2rem;
    background:
      linear-gradient(135deg, var(--cover-from), var(--cover-to)),
      linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0));
  }

  .cover span {
    display: inline-flex;
    border-radius: 999px;
    padding: 0.45rem 0.7rem;
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    backdrop-filter: blur(8px);
  }

  .content {
    padding: 1.4rem 1.4rem 1.25rem;
  }

  .meta {
    margin: 0;
    color: #64748b;
    font-size: 0.9rem;
  }

  h2 {
    margin: 0.4rem 0 0.8rem;
    font-size: clamp(1.35rem, 2vw, 1.9rem);
    line-height: 1.1;
  }

  .excerpt {
    margin: 0;
    color: #334155;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tags span {
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: #f8fafc;
    color: #475569;
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .post-link {
      grid-template-columns: 1fr;
    }

    .cover {
      min-height: 13rem;
    }
  }
</style>
