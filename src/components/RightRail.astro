---
const {
  categories = [],
  tags = [],
  compact = false,
} = Astro.props;
---

<aside class="rail" id="explore">
  <section class="panel">
    <p class="panel-label">查询</p>
    <label class="search" for="post-search">
      <span class="sr-only">搜索文章</span>
      <input
        id="post-search"
        type="search"
        placeholder="搜索标题、摘要、标签"
        data-search-input
      />
    </label>
  </section>

  <section class="panel">
    <p class="panel-label">分类</p>
    <div class="chip-grid">
      {categories.map((category) => (
        <button type="button" class="chip" data-filter-type="category" data-filter-value={category}>
          {category}
        </button>
      ))}
    </div>
  </section>

  <section class="panel">
    <p class="panel-label">标签</p>
    <div class="chip-grid">
      {tags.map((tag) => (
        <button type="button" class:list={["chip", "subtle", { compact }]} data-filter-type="tag" data-filter-value={tag}>
          #{tag}
        </button>
      ))}
    </div>
  </section>
</aside>

<style>
  .rail {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .panel {
    padding: 1.1rem;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(148, 163, 184, 0.18);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
  }

  .panel-label {
    margin: 0 0 0.85rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #475569;
  }

  .search {
    display: block;
  }

  .search input {
    width: 100%;
    border: 1px solid rgba(148, 163, 184, 0.26);
    border-radius: 999px;
    padding: 0.85rem 1rem;
    font: inherit;
    color: #0f172a;
    background: #fff;
    box-sizing: border-box;
  }

  .chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .chip {
    border: 0;
    border-radius: 999px;
    padding: 0.55rem 0.85rem;
    font: inherit;
    cursor: pointer;
    color: #0f172a;
    background: #e0f2fe;
  }

  .chip.subtle {
    background: #f1f5f9;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
